{
  "name": "@regboy/retailctrl-contracts",
  "version": "0.1.0",
  "description": "Shared API contracts (Zod schemas + inferred types) for RetailCtrl services.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./priceCheck": {
      "types": "./dist/priceCheck/index.d.ts",
      "import": "./dist/priceCheck/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "zod": "^4.3.6"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED",
  "private": true
}

{
  "name": "@regboy744/retailctrl-contracts",
  "version": "0.1.3",
  "description": "Shared API contracts (Zod schemas + inferred types) for RetailCtrl services.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./priceCheck": {
      "types": "./dist/priceCheck/index.d.ts",
      "import": "./dist/priceCheck/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.4",
    "zod": "^4.3.6"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Regboy744/retailctrl-contracts.git"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED"
}
